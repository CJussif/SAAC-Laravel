# =============================================================
# SAAC-Laravel — variables de PRODUCCIÓN (Docker + Cloudflare Tunnel)
# En el VPS:  cp .env.production.example .env.production  y rellena lo marcado.
# NO subas .env.production a git (ya está en .gitignore).
# =============================================================

APP_NAME="S.A.A.C. TESCHa"
APP_ENV=production
APP_KEY=  # <-- deploy.sh lo genera automáticamente si está vacío
APP_DEBUG=false
APP_URL=https://tescha.tlapala.com

APP_LOCALE=es
APP_FALLBACK_LOCALE=es

LOG_CHANNEL=stack
LOG_LEVEL=warning

# ---- Base de datos (SQLite; el archivo vive en el volumen sqlite_data) ----
DB_CONNECTION=sqlite
DB_DATABASE=/var/www/html/database/database.sqlite

# ---- Sesión / caché / colas (todo en BD; sin Redis) ----
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_SECURE_COOKIE=true
SESSION_DOMAIN=null
CACHE_STORE=database
QUEUE_CONNECTION=database

# ---- Correo ('log' = no envía, solo escribe en logs) ----
MAIL_MAILER=log
MAIL_FROM_ADDRESS="no-reply@tescha.tlapala.com"
MAIL_FROM_NAME="${APP_NAME}"

FILESYSTEM_DISK=local
BROADCAST_CONNECTION=log

# ---- Cloudflare Tunnel ----
# Token del túnel creado en Zero Trust > Networks > Tunnels
# (hostname tescha.tlapala.com -> http://web:80)
CLOUDFLARE_TUNNEL_TOKEN=eyJ...tu-token-del-tunel-aqui...
